# 复制本文件为 .env 并按需修改（生产环境务必修改）
# 服务端口
PORT=3000
# 监听地址（容器/服务器用 0.0.0.0）
HOST=0.0.0.0
# 运行环境：production 时自动开启安全 Cookie
NODE_ENV=production
# 当部署在 HTTPS 反向代理后，强制开启 Secure Cookie（1 开启）
COOKIE_SECURE=1
# 登录 Token 签名密钥——务必改成你自己的长随机字符串！
AUTH_SECRET=please-change-this-to-a-long-random-secret
# MongoDB 连接串（设置后自动启用云数据库；留空则用本地 JSON 文件）
# 形如： mongodb+srv://用户名:密码@cluster0.xxxx.mongodb.net/recharge?retryWrites=true&w=majority
MONGODB_URI=
# MongoDB 数据库名（可选，默认 recharge）
MONGODB_DB=recharge
